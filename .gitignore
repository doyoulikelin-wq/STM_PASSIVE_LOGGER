# --- runtime data (per-machine, never commit) ---
data/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# --- bundled Python runtime (regenerated by build, too large for repo) ---
python_runtime/

# --- python build/cache ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/

# --- IDE / editor ---
.vscode/
.idea/
*.swp

# --- OS ---
Thumbs.db
.DS_Store

# --- local-only test scripts (never shipped) ---
_local_test/
_local_smoke_test.py
_live_test*.py

# --- distribution artifacts (built, not source) ---
*.zip
git-installer.exe
git-install.inf
